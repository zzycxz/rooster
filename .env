# Rooster Environment Configuration
# 非敏感配置（模型路由、行为策略、服务地址等）
# 密钥统一存放在 .env.local（不提交 git）
# Version: 0.3.5 (see pyproject.toml)

# --- 本地模型 ---
LOCAL_URL=http://127.0.0.1:9090/v1
LOCAL_KEY=llama.cpp
LOCAL_MODEL=Qwen3.5-4B-Q4_K_M.gguf

# --- Ollama ---
OLLAMA_URL=http://localhost:11434

# --- 故障转移 ---
LLM_FAILOVER_ENABLED=true
LLM_FAILOVER_ORDER=jiutian,zhipu,mimo,local
LLM_FAILOVER_RETRY_MAX=2

# --- 角色路由 (Strategist/Executor/Auditor/Router/Solo) ---
STRATEGIST_MODEL_MODE=zhipu
STRATEGIST_MODEL_NAME=glm-5.1

EXECUTOR_MODEL_MODE=jiutian
EXECUTOR_MODEL_NAME=openai/gpt-oss-120b

# --- LLM Providers ---
ZHIPU_URL=https://open.bigmodel.cn/api/coding/paas/v4
ZHIPU_KEY=  # → 见 .env.local
ZHIPU_MODEL=GLM-5.1

ZHIPU_GLM_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_GLM_KEY=  # → 见 .env.local
ZHIPU_GLM_MODEL=glm-4-flash

OPENAI_URL=https://api.openai.com/v1
OPENAI_KEY=  # → 见 .env.local
OPENAI_MODEL=gpt-4o

ANTHROPIC_URL=https://api.anthropic.com
ANTHROPIC_KEY=  # → 见 .env.local
ANTHROPIC_MODEL=claude-sonnet-4-20250514

KIMI_URL=https://api.moonshot.cn/v1
KIMI_KEY=  # → 见 .env.local
KIMI_MODEL=moonshot-v1-32k

QWEN_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_KEY=  # → 见 .env.local
QWEN_MODEL=qwen-plus

JIUTIAN_URL=https://jiutian.10086.cn/largemodel/moma/api/v3
JIUTIAN_KEY=  # → 见 .env.local
JIUTIAN_MODEL=openai/gpt-oss-120b
JIUTIAN_MODEL_FAST=qwen/qwen3.6-35b

MIMO_URL=https://api.xiaomimimo.com/v1
MIMO_KEY=  # → 见 .env.local
MIMO_MODEL=mimo-v2.5
MIMO_THINKING_ENABLED=false  # MiMo 思考模式已关闭（开启时需确保 reasoning_content 完整回传）

# --- 嵌入模型 ---
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5

# --- 审计官 ---
AUDITOR_MODEL_MODE=jiutian
AUDITOR_VISION_MODEL=openai/gpt-oss-120b
AUDITOR_TEXT_MODEL=openai/gpt-oss-120b

# --- 路由官 ---
ROUTER_MODEL_MODE=zhipu
ROUTER_MODEL_NAME=GLM-5.1

# --- 语义重构 ---
REFRAMER_MODEL_MODE=mimo
REFRAMER_MODEL_NAME=mimo-v2.5
ENABLE_REFRAMER=false

# --- 直接对话 (SOLO/TALK) ---
SOLO_MODEL_MODE=mimo
SOLO_MODEL_NAME=mimo-v2.5
SOLO_FAILOVER_ORDER=mimo,jiutian,zhipu,local

# --- Provider 上下文字符上限 (0=无限制) ---
PROVIDER_CONTEXT_LIMITS=mimo:500000

# --- Agent 运行时 ---
AGENT_CONTEXT_LIMIT=131072
AGENT_MAX_STEPS=50

# --- 蒸馏调度器 ---
DISTILLATION_ENABLED=true
DISTILLATION_INTERVAL=600
DISTILLATION_QUIET_MINUTES=5
DISTILLATION_MODEL=glm-5.1

# --- 上下文配额 ---
CONTEXT_RATIO_LTM=0.10
CONTEXT_RATIO_OBS=0.20
CONTEXT_RATIO_HISTORY=0.70
CONTEXT_RATIO_BUFFER=0.00

# --- 审计策略 ---
AUDIT_STRICTNESS=Medium
AUDIT_REQUIRE_SCREENSHOT=True
AUDIT_MAX_REMAND_RETRY=1
AUDIT_CONFIDENCE_THRESHOLD=0.6

LOG_LEVEL=INFO

# --- 搜索 ---
ENABLE_SEARCH_DDG=true
ENABLE_SEARCH_SEARXNG=true
ENABLE_SEARCH_BAIDU=true
SEARXNG_URL=http://127.0.0.1:18088
ENABLE_SEARCH_TAVILY=true
TAVILY_API_KEY=  # → 见 .env.local
E2B_API_KEY=  # → 见 .env.local

# --- 下载 ---
DOWNLOADER_PROVIDER=system_default
DOWNLOADER_ENABLED=true
ARIA2_RPC_URL=http://localhost:6800/jsonrpc
ARIA2_RPC_SECRET=

# --- Hugging Face ---
HF_ENDPOINT=https://huggingface.co

# --- 视觉感知 (YOLO Grounding) ---
VISION_MODEL_PATH=resources/models/grounding/icon_detect/model.pt
VISION_CONFIDENCE=0.45
VISION_FONT_SIZE_BASE=14
VISION_FONT_BASE_HEIGHT=1080
VISION_FONT_SIZE_MIN=14
VISION_LABEL_OFFSET_X=12
VISION_LABEL_OFFSET_Y=-12

# --- 动作控制 ---
ACTION_WAIT_MS=500
ACTION_RETRY_MAX=2
ACTION_DRIFT_PX=2
ACTION_HASH_SIMILARITY=0.98
INPUT_USE_CLIPBOARD=True
INPUT_PRE_CLEAR=True
SCROLL_DEFAULT_AMOUNT=600
SCROLL_OVERLAP_PX=150
SCROLL_WAIT_MS=300
AUDIT_VISUAL_SNAPSHOT=False
AUDIT_SNAPSHOT_DIR=.rooster/audit/vision/
MEMORY_VISUAL_BUFFER_SIZE=5

# --- 隐私路由 ---
LOCAL_DIRS=
# 敏感文件夹，路径匹配即走本地模型，逗号分隔
# 示例: LOCAL_DIRS=~/private,~/confidential,~/medical

# --- 权限策略 ---
PERMISSION_POLICY=balanced
BLOCKED_TOOLS=
ALLOWED_TOOLS=
ALLOWED_PATHS=*

# --- Webhook ---
WEBHOOK_ENABLED=false
WEBHOOK_PORT=8766
WEBHOOK_SECRET_TOKEN=

# --- MCP ---
MCP_DYNAMIC_ENABLED=false
MCP_SERVER_URLS=

# --- Gateway ---
GATEWAY_PORT=8765
GATEWAY_LOCALHOST_AUTH=true

# --- 稳定性 ---
CHECKPOINT_ENABLED=true
STRATEGIST_LLM_TIMEOUT=90

# --- 运行时功能 ---
INTERPRETER_ALLOW_LOCAL=true
INTERPRETER_STRIP_PROXY=false

# --- 飞书 ---
FEISHU_APP_ID=  # → 见 .env.local
FEISHU_APP_SECRET=  # → 见 .env.local
FEISHU_USER_OPEN_ID=  # → 见 .env.local