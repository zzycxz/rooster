# .env.local — secrets template
# Copy this file to .env.local, fill in real values, do not commit to git
#
# cp .env.local.example .env.local

# --- Zhipu AI (CodingPlan) ---
ZHIPU_KEY=

# --- Zhipu MCP Search (单独密钥，空则回退到 ZHIPU_KEY) ---
ZHIPU_MCP_SEARCH_KEY=

# --- Zhipu AI (Standard GLM) ---
ZHIPU_GLM_KEY=

# --- Embedding model (Zhipu alternative) ---
EMBEDDING_KEY=

# --- Jiutian MoMA ---
JIUTIAN_KEY=

# --- Xiaomi MiMo ---
MIMO_KEY=

# --- OpenAI ---
OPENAI_KEY=

# --- Anthropic Claude ---
ANTHROPIC_KEY=

# --- Kimi (Moonshot AI) ---
KIMI_KEY=

# --- Qwen (Tongyi Qianwen) ---
QWEN_KEY=

# --- Tavily Search ---
TAVILY_API_KEY=

# --- Exa.ai Neural Search (1000 free searches/month) ---
EXA_KEY=

# --- Linkup.so Agentic Web Search ---
LINKUP_KEY=

# --- E2B Code Sandbox ---
E2B_API_KEY=

# --- Feishu ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_OPEN_ID=

# --- Aria2 Downloader ---
ARIA2_RPC_SECRET=

# --- Gateway security (leave empty = skip auth for local dev) ---
GATEWAY_API_KEY=
WEBHOOK_HMAC_SECRET=

# --- Proxy (set if using Clash / similar local proxy) ---
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost

